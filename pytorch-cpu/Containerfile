FROM quay.io/fedora/fedora-bootc:41

# Install development tools and dependencies
RUN dnf install -y \
    git \
    vim-enhanced \
    python3 \
    python3-pip \
    python3-devel \
    gcc \
    gcc-c++ \
    cmake \
    ninja-build \
    && dnf clean all

# Create a virtual environment for Python packages
RUN python3 -m venv /opt/pytorch-env

# Install PyTorch (CPU-only) and related ML packages
RUN /opt/pytorch-env/bin/pip install --no-cache-dir \
    torch --index-url https://download.pytorch.org/whl/cpu \
    && /opt/pytorch-env/bin/pip install --no-cache-dir \
    torchvision \
    torchaudio \
    numpy \
    pandas \
    scikit-learn \
    jupyter \
    matplotlib \
    seaborn

# Add activation script for the environment
RUN echo 'source /opt/pytorch-env/bin/activate' >> /etc/profile.d/pytorch.sh

# Enable SSH for remote development
RUN systemctl enable sshd

# Create a workspace directory
RUN mkdir -p /workspace && chmod 1777 /workspace

# Set up admin user with locked password (inject SSH keys at deploy time)
RUN useradd -m -G wheel admin && \
    passwd -l admin && \
    echo "admin ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers.d/admin && \
    sed -i 's/^#*PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config

LABEL org.opencontainers.image.title="PyTorch CPU Bootc Workstation"
LABEL org.opencontainers.image.description="Bootable ML/AI development environment with PyTorch (CPU-only)"
